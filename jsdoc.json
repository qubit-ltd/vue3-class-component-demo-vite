{
  "source": {
    "include": [
      "./src/"
    ],
    "includePattern": "\\.js$",
    "exclude": [
      "node_modules/"
    ]
  },
  "opts": {
    "destination": "./doc/",
    "recurse": true,
    "readme": "./README.md",
    "template": "node_modules/@qubit-ltd/jsdoc-theme",
    "theme_opts": {
      "language": "zh"
    }
  },
  "plugins": [
    "plugins/markdown"
  ],
  "templates": {
    "cleverLinks": false,
    "monospaceLinks": false
  }
}
